{
  "name": "widget-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "next dev -p 3001",
    "build:embed": "node scripts/build-embed.js",
    "build:sri": "node scripts/generate-sri.js",
    "build": "QUIET_LOCALE=1 npm run build:embed && npm run check-locales && next build && npm run build:sri && npm run test:coverage",
    "heroku-postbuild": "QUIET_LOCALE=1 npm run build:embed && next build",
    "check-locales": "QUIET_LOCALE=1 python3 scripts/check_locale_issues.py && QUIET_LOCALE=1 python3 scripts/ci_warn_if_empty.py",
    "size-limit": "size-limit",
    "ci:size-limit": "npm run build && npm run size-limit",
    "analyze": "ANALYZE=true next build --webpack",
    "analyze:open": "npx serve .next/analyze --listen 8000",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --runInBand",
    "dev:widget": "next dev -p 3001"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@size-limit/preset-small-lib": "^7.0.8",
    "@size-limit/webpack": "^7.0.8",
    "@size-limit/webpack-why": "^7.0.8",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.33",
    "axe-core": "^4.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.2.6",
    "embla-carousel-react": "^8.6.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-plugin-testing-library": "^7.16.1",
    "jest-axe": "^10.0.0",
    "lucide-react": "^0.561.0",
    "motion": "^12.26.2",
    "nanoid": "^5.1.6",
    "next": "^16.0.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^8.0.7",
    "remark-gfm": "^3.0.1",
    "shiki": "^3.21.0",
    "size-limit": "^7.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "use-stick-to-bottom": "^1.1.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.0",
    "@types/jest": "^29.5.0",
    "baseline-browser-mapping": "^2.10.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
