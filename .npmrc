# Heap ceiling for npm-run processes. npm exports this as NODE_OPTIONS for every
# `npm run` script, so it must be high enough for the heaviest one: the Next.js
# webpack dev/build compile (HMR + source maps). 512 MB OOM'd `next dev`
# ("Reached heap limit" at ~510 MB); 4096 gives the compiler room. This is a
# ceiling, not a reservation — the runtime server still only uses what it needs.
node-options=--max-old-space-size=4096
